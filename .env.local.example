# =====================================================
# WOMPI — Pasarela de pago de Bancolombia
# =====================================================
# Obtén tus llaves en: https://comercios.wompi.co/  →  Configuración → API
#
# 1) MODO TEST (sandbox)
#    Usa estas llaves para probar sin cargos reales:
#      pub_test_xxxxxxxxxx
#      WOMPI_INTEGRITY_SECRET=xxxxxxxxxx
#
# 2) MODO PRODUCCIÓN
#    Cuando estés listo, reemplaza por:
#      pub_prod_xxxxxxxxxx
# =====================================================

# Llave pública (visible en el frontend)
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_TU_LLAVE_AQUI

# Secreto de integridad (NUNCA commitear, solo server-side)
WOMPI_INTEGRITY_SECRET=tu_integrity_secret_aqui

# Secreto de eventos (para validar webhooks)
WOMPI_EVENTS_SECRET=tu_events_secret_aqui

# URL pública del sitio (usada para redirect tras pago)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tasa USD → COP (Wompi solo acepta COP en producción CO)
# Si tus precios ya están en COP, pon 1
NEXT_PUBLIC_USD_TO_COP_RATE=4000

# =====================================================
# CONFIGURACIÓN POST-DEPLOY
# =====================================================
# 1. Configurar webhook en Wompi dashboard:
#    URL: https://tu-dominio.com/api/wompi/webhook
#
# 2. Tarjetas de prueba (sandbox):
#    Aprobada:    4242 4242 4242 4242
#    Rechazada:   4111 1111 1111 1111
#    CVV: cualquier 3 dígitos
#    Vence: cualquier fecha futura
# =====================================================
